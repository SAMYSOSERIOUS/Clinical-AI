# ─────────────────────────────────────────────────────────────────────────────
#  Health AI Project — Environment Variable Template
#  Copy this file to .env and fill in your real keys.
#  NEVER commit .env to version control — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Required — powers the LangGraph clinical AI agent (GPT-4o-mini)
OPENAI_API_KEY=sk-proj-...your-key-here...

# Optional — enables LangSmith tracing dashboard
LANGCHAIN_API_KEY=ls__...your-key-here...

# ── Production only (set in Render dashboard, not here) ──────────────────────
# ALLOWED_ORIGINS=https://health-ai-frontend.onrender.com
